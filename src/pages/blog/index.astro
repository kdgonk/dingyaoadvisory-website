---
import BaseLayout from '../../layouts/BaseLayout.astro';

// 未來會從 content collection 讀取文章列表
const posts = [];
---

<BaseLayout title="部落格" description="鼎曜國際顧問部落格 - 投資觀點與市場分析">
  <h1>部落格</h1>
  <p>投資觀點與市場分析</p>
  
  {posts.length === 0 && (
    <p>文章即將上線...</p>
  )}
  
  <ul>
    {posts.map((post) => (
      <li>
        <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
        <time>{post.data.pubDate}</time>
      </li>
    ))}
  </ul>
</BaseLayout>